# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ioms?schema=public"
# Direct (non-pooled) connection for prisma migrate — needed if DATABASE_URL uses a pooler (pgbouncer).
DIRECT_URL=

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── SMTP (email notifications) ──────────────────────────
# Microsoft 365 / Office 365: smtp.office365.com, port 587 (STARTTLS).
# Note: many M365 tenants have basic-auth SMTP disabled by default — if auth
# fails, an admin must enable "SMTP AUTH" for the mailbox in the Exchange
# admin center, or you'll need an App Password / OAuth2 sender instead.
# Gmail / Google Workspace: smtp.gmail.com, port 587, requires an App Password.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IOMS <no-reply@yourdomain.com>"

# ── File uploads ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
MAX_DOC_SIZE_MB=50

# ── Logging & monitoring ────────────────────────────────
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ── Brute-force lockout ─────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ── Email queue (optional; falls back to inline if unset) ─
REDIS_URL=

# ── Supabase Storage (media uploads) ────────────────────
# When these are set, ALL media (asset images, documents, avatars, ticket
# files, QR codes) is uploaded to Supabase Storage buckets instead of local
# disk. Leave BLANK to use local disk storage (the app works either way).
#
# Create these PUBLIC buckets in your Supabase project (Storage > New bucket):
#   asset-image, asset-document, user-avatar, ticket-image,
#   ticket-document, qr-code, other-files
# Use the SERVICE ROLE key (Project Settings > API > service_role) — it is
# secret and must only ever live on the server, never in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
