# ── SMTP (email notifications) ──────────────────────────
# Configured for Microsoft 365 / Office 365 — ict@sixcontinentalgroup.africa.
# smtp.office365.com:587 (STARTTLS) is the standard Microsoft 365 SMTP relay
# for any custom domain that routes mail through Exchange Online.
#
# IMPORTANT: Microsoft has disabled basic-auth SMTP (plain username+password)
# for many tenants by default since 2022, in favor of OAuth2 / modern auth.
# If emails fail with an authentication error (not a connection error), that
# almost always means:
#   1. SMTP AUTH is disabled tenant-wide or for this mailbox — an admin must
#      enable it in the Exchange admin center (Recipients > Mailboxes >
#      [this mailbox] > Mail flow settings > SMTP AUTH), OR
#   2. The mailbox has MFA enabled and needs an App Password instead of the
#      regular login password (Security info > Add sign-in method > App
#      password, if available on this tenant's Conditional Access policy).
# If neither is available, an OAuth2-based sender (e.g. Microsoft Graph API)
# is the modern-auth alternative — a larger change than swapping env vars.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=ict@sixcontinentalgroup.africa
SMTP_PASS=123456
SMTP_FROM="IOMS <ict@sixcontinentalgroup.africa>"

# ── File uploads ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
MAX_DOC_SIZE_MB=50

# ── Logging & monitoring ────────────────────────────────
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ── Brute-force lockout ─────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ── Email queue (optional; falls back to inline if unset) ─
REDIS_URL=

# ── Supabase Storage (media uploads) ────────────────────
# When these are set, ALL media (asset images, documents, avatars, ticket
# files) is uploaded to Supabase Storage buckets instead of local disk.
# Leave BLANK to use local disk storage (the app works either way).
#
# Create these PUBLIC buckets in your Supabase project (Storage > New bucket):
#   asset-image, asset-document, user-avatar, ticket-image,
#   ticket-document, qr-code, other-files
# Use the SERVICE ROLE key (Project Settings > API > service_role) — it is
# secret and must only ever live on the server, never in the frontend.
