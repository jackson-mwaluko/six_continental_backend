// ============================================================================
//  IOMS — ICT Operations Management System
//  Prisma schema (PostgreSQL)
//  Covers all 14 modules. This is the single source of truth for the data model.
// ============================================================================

generator client {
  provider = "prisma-client-js"
  // Add binary targets for both local development (native) and Render (debian)
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
//  ENUMS
// ----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ICT_ADMIN
  ICT_TECHNICIAN
  DEPARTMENT_MANAGER
  EMPLOYEE
}

enum TicketCategory {
  COMPUTER
  PRINTER
  NETWORK
  INTERNET
  SOFTWARE
  EMAIL
  CCTV
  ERP
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum AssetType {
  LAPTOP
  DESKTOP
  PRINTER
  ROUTER
  SWITCH
  UPS
  MOBILE_PHONE
  CCTV_DEVICE
  OTHER
}

enum AssetStatus {
  IN_STOCK
  ASSIGNED
  IN_REPAIR
  RETIRED
  DISPOSED
  LOST
}

enum AssignmentStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum SubscriptionType {
  WIFI
  INTERNET
  DOMAIN
  HOSTING
  MICROSOFT_365
  GOOGLE_WORKSPACE
  ANTIVIRUS
  OTHER_LICENSE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum MaintenanceFrequency {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum AuditType {
  ASSET_AUDIT
  WARRANTY_AUDIT
  LICENSE_COMPLIANCE
  SECURITY_REVIEW
}

enum AuditResult {
  PASS
  FAIL
  NEEDS_REVIEW
  PENDING
}

enum NotificationType {
  TICKET
  SLA_BREACH
  ASSET
  SUBSCRIPTION_RENEWAL
  MAINTENANCE
  LOW_STOCK
  LOW_TONER
  SYSTEM
}

// ----------------------------------------------------------------------------
//  CORE — Users, Departments, Auth
// ----------------------------------------------------------------------------

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  manager   User?    @relation("DepartmentManager", fields: [managerId], references: [id])
  managerId String?
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  jobTitle     String?
  avatarUrl    String?
  role         Role      @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  managedDepts Department[] @relation("DepartmentManager")

  // Helpdesk
  createdTickets   Ticket[] @relation("TicketRequester")
  assignedTickets  Ticket[] @relation("TicketAssignee")
  ticketComments   TicketComment[]
  ticketHistory    TicketHistory[]

  // Assets
  assignmentsReceived AssetAssignment[] @relation("AssignmentEmployee")
  assignmentsIssued   AssetAssignment[] @relation("AssignmentIssuedBy")

  // Project management
  projectsLed   Project[] @relation("ProjectLead")
  assignedTasks ProjectTask[]

  // Maintenance
  maintenanceAssigned Maintenance[] @relation("MaintenanceAssignee")

  // Knowledge base
  articles KnowledgeArticle[]

  // Audits
  auditsConducted Audit[] @relation("AuditConductedBy")

  // Notifications & activity
  notifications Notification[]
  activityLogs  ActivityLog[]
  assetRequestsMade     AssetRequest[] @relation("RequestRequester")
  assetRequestsReviewed AssetRequest[] @relation("RequestReviewer")
  documents     Document[]

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
//  MODULE 1 — Helpdesk Ticketing
// ----------------------------------------------------------------------------

model Ticket {
  id          String         @id @default(cuid())
  ticketNo    String         @unique // e.g. IOMS-000123
  subject     String
  description String
  category    TicketCategory
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)

  requesterId String
  requester   User           @relation("TicketRequester", fields: [requesterId], references: [id])
  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])

  assetId     String?
  asset       Asset?         @relation(fields: [assetId], references: [id])

  // SLA tracking
  slaPolicyId    String?
  slaPolicy      SlaPolicy? @relation(fields: [slaPolicyId], references: [id])
  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  slaBreached        Boolean    @default(false)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  comments    TicketComment[]
  history     TicketHistory[]
  attachments Attachment[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assigneeId])
}

model SlaPolicy {
  id                 String         @id @default(cuid())
  name               String
  priority           TicketPriority
  firstResponseMins  Int            // minutes to first response
  resolutionMins     Int            // minutes to resolution
  isActive           Boolean        @default(true)
  tickets            Ticket[]
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  body       String
  isInternal Boolean  @default(false) // internal note vs. user-visible
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model TicketHistory {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  field     String   // e.g. "status", "assignee", "priority"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model Attachment {
  id         String   @id @default(cuid())
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  ticketId   String?
  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  handoverId String?
  handover   Handover? @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
//  MODULE 2 — ICT Asset Management
// ----------------------------------------------------------------------------

model Asset {
  id            String      @id @default(cuid())
  serialNumber  String      @unique // serial number or asset code — the unique identifier
  name          String
  type          AssetType
  status        AssetStatus @default(IN_STOCK)
  model         String?
  manufacturer  String?
  specifications String?

  purchaseDate  DateTime?
  purchaseCost  Decimal?    @db.Decimal(12, 2)
  warrantyStart DateTime?
  warrantyEnd   DateTime?
  location      String?

  vendorId      String?
  vendor        Vendor?     @relation(fields: [vendorId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  assignments   AssetAssignment[]
  history       AssetHistory[]
  tickets       Ticket[]
  printer       Printer?
  maintenances  Maintenance[]
  requests      AssetRequest[]

  @@index([type])
  @@index([status])
}

model AssetHistory {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action    String   // CREATED, STATUS_CHANGE, ASSIGNED, RETURNED, TRANSFERRED, REPAIR, etc.
  details   String?
  performedBy String?
  createdAt DateTime @default(now())

  @@index([assetId])
}

// ----------------------------------------------------------------------------
//  MODULE 3 — Device Assignment / Handover
// ----------------------------------------------------------------------------

model AssetAssignment {
  id           String           @id @default(cuid())
  assetId      String
  asset        Asset            @relation(fields: [assetId], references: [id])
  employeeId   String
  employee     User             @relation("AssignmentEmployee", fields: [employeeId], references: [id])
  issuedById   String
  issuedBy     User             @relation("AssignmentIssuedBy", fields: [issuedById], references: [id])
  status       AssignmentStatus @default(ACTIVE)
  assignedAt   DateTime         @default(now())
  returnedAt   DateTime?
  conditionOut String?
  conditionIn  String?
  notes        String?

  handover     Handover?

  @@index([assetId])
  @@index([employeeId])
}

model Handover {
  id           String   @id @default(cuid())
  assignmentId String   @unique
  assignment   AssetAssignment @relation(fields: [assignmentId], references: [id])
  documentNo   String   @unique
  signedByEmployee Boolean @default(false)
  signedByIct      Boolean @default(false)
  signedAt     DateTime?
  attachments  Attachment[]
  createdAt    DateTime @default(now())
}

// ----------------------------------------------------------------------------
//  MODULE 4 — Printer & Toner Management
// ----------------------------------------------------------------------------

model Printer {
  id            String   @id @default(cuid())
  assetId       String   @unique
  asset         Asset    @relation(fields: [assetId], references: [id])
  modelName     String
  monoSupported Boolean  @default(true)
  colorSupported Boolean @default(false)
  monthlyDutyCycle Int?
  toners        Toner[]
}

model Toner {
  id             String   @id @default(cuid())
  printerId      String
  printer        Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
  partNumber     String
  color          String   // BLACK, CYAN, MAGENTA, YELLOW
  expectedYield  Int      // pages rated
  installedDate  DateTime @default(now())
  installedAtPageCount Int @default(0)
  currentPageCount     Int @default(0)
  avgDailyPages  Int?     // for depletion estimate
  estimatedDepletionDate DateTime?
  lowThresholdPct Int     @default(15)
  isDepleted     Boolean  @default(false)
  replacedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([printerId])
}

// ----------------------------------------------------------------------------
//  MODULE 5 — Subscription & License Management
// ----------------------------------------------------------------------------

model Subscription {
  id            String             @id @default(cuid())
  name          String
  type          SubscriptionType
  provider      String?
  status        SubscriptionStatus @default(ACTIVE)
  seats         Int?
  cost          Decimal?           @db.Decimal(12, 2)
  billingCycle  String?            // MONTHLY, ANNUAL, etc.
  startDate     DateTime?
  renewalDate   DateTime?
  expiryDate    DateTime?
  reminderDaysBefore Int           @default(30) // configurable interval
  autoRenew     Boolean            @default(false)
  notes         String?
  vendorId      String?
  vendor        Vendor?            @relation(fields: [vendorId], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status])
  @@index([renewalDate])
}

// ----------------------------------------------------------------------------
//  MODULE 6 — Preventive Maintenance
// ----------------------------------------------------------------------------

model Maintenance {
  id          String               @id @default(cuid())
  title       String
  description String?
  assetId     String?
  asset       Asset?               @relation(fields: [assetId], references: [id])
  frequency   MaintenanceFrequency @default(ONE_TIME)
  status      MaintenanceStatus    @default(SCHEDULED)
  scheduledDate DateTime
  completedDate DateTime?
  nextDueDate   DateTime?
  assigneeId  String?
  assignee    User?                @relation("MaintenanceAssignee", fields: [assigneeId], references: [id])
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  logs        MaintenanceLog[]

  @@index([status])
  @@index([scheduledDate])
}

model MaintenanceLog {
  id            String      @id @default(cuid())
  maintenanceId String
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  performedAt   DateTime    @default(now())
  performedBy   String?
  outcome       String?
  notes         String?
}

// ----------------------------------------------------------------------------
//  MODULE 7 — Inventory Management
// ----------------------------------------------------------------------------

model InventoryItem {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  category     String   // CONSUMABLE, SPARE_PART, etc.
  unit         String   @default("pcs")
  quantity     Int      @default(0)
  reorderLevel Int      @default(5)
  unitCost     Decimal? @db.Decimal(12, 2)
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements    StockMovement[]

  @@index([category])
}

model StockMovement {
  id         String            @id @default(cuid())
  itemId     String
  item       InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type       StockMovementType
  quantity   Int
  reason     String?
  reference  String?
  performedBy String?
  createdAt  DateTime          @default(now())

  @@index([itemId])
}

// ----------------------------------------------------------------------------
//  MODULE 8 — Vendor Management
// ----------------------------------------------------------------------------

model Vendor {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  email       String?
  phone       String?
  website     String?
  address     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts      VendorContact[]
  contracts     Contract[]
  assets        Asset[]
  subscriptions Subscription[]
}

model VendorContact {
  id       String  @id @default(cuid())
  vendorId String
  vendor   Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name     String
  title    String?
  email    String?
  phone    String?
  isPrimary Boolean @default(false)
}

model Contract {
  id           String   @id @default(cuid())
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title        String
  contractNo   String?  @unique
  description  String?
  value        Decimal? @db.Decimal(12, 2)
  startDate    DateTime?
  endDate      DateTime?
  slaTerms     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ----------------------------------------------------------------------------
//  MODULE 9 — Knowledge Base
// ----------------------------------------------------------------------------

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String
  category  String
  tags      String[] // PostgreSQL text array
  isPublished Boolean @default(true)
  views     Int      @default(0)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ----------------------------------------------------------------------------
//  MODULE 10 — ICT Project Management
// ----------------------------------------------------------------------------

model Project {
  id          String        @id @default(cuid())
  name        String
  code        String?       @unique
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  progress    Int           @default(0) // 0-100
  leadId      String?
  lead        User?         @relation("ProjectLead", fields: [leadId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  milestones  Milestone[]
  tasks       ProjectTask[]
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ProjectTask {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  assigneeId  String?
  assignee    User?      @relation(fields: [assigneeId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
}

// ----------------------------------------------------------------------------
//  MODULE 11 — Audit & Compliance
// ----------------------------------------------------------------------------

model Audit {
  id          String      @id @default(cuid())
  title       String
  type        AuditType
  result      AuditResult @default(PENDING)
  scope       String?
  findings    String?
  conductedById String?
  conductedBy   User?     @relation("AuditConductedBy", fields: [conductedById], references: [id])
  conductedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@index([type])
}

// ----------------------------------------------------------------------------
//  MODULE 13 — Notification Center
// ----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

// ----------------------------------------------------------------------------
//  Cross-cutting — Activity Log / Audit Trail
// ----------------------------------------------------------------------------

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity    String   // "Ticket", "Asset", ...
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

enum AssetRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model AssetRequest {
  id            String             @id @default(cuid())
  assetId       String?
  asset         Asset?             @relation(fields: [assetId], references: [id])
  requesterId   String
  requester     User               @relation("RequestRequester", fields: [requesterId], references: [id])
  reason        String?
  status        AssetRequestStatus @default(PENDING)
  reviewerId    String?
  reviewer      User?              @relation("RequestReviewer", fields: [reviewerId], references: [id])
  reviewComment String?
  decidedAt     DateTime?
  createdAt     DateTime           @default(now())

  @@index([requesterId])
  @@index([status])
}

enum DocumentCategory {
  PRESENTATION
  MEETING_NOTES
  POLICY
  TEMPLATE
  REPORT
  DIAGRAM
  OTHER
}

model Document {
  id           String           @id @default(cuid())
  title        String
  description  String?
  category     DocumentCategory @default(OTHER)
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  uploadedById String
  uploadedBy   User             @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime         @default(now())

  @@index([category])
  @@index([createdAt])
}